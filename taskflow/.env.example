# All variables are optional — the app runs with sensible defaults out of the box.

# Used to build absolute URLs for Open Graph tags, canonical links, and the
# sitemap on publicly shared board pages. Defaults to http://localhost:3000.
# Set this to your real domain in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# How long a login session lasts, in milliseconds. Defaults to 30 minutes
# (1800000). Lower this for a quick demo of the session-expiry flow, e.g.
# SESSION_TTL_MS=60000 for 1 minute. There's also a "Simulate expired
# session" button in the navbar that doesn't require changing this at all.
SESSION_TTL_MS=1800000

# Secret used to sign the mock session token (HMAC-SHA256). Change this for
# any deployment that isn't purely local/demo use.
SESSION_SECRET=taskflow-dev-secret-do-not-use-in-prod
